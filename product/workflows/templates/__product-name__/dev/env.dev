# @saflib/env
ALLOW_DB_CREATION=true
DEPLOYMENT_NAME=development
MOCK_INTEGRATIONS=true
NODE_ENV=development
PROTOCOL=http
TZ=UTC

# __product-name__-specific @saflib/env
TRADEMARK=__ProductName__
DOMAIN=docker.localhost
CLIENT_SUBDOMAINS=,auth,app,admin,account
SERVICE_SUBDOMAINS=identity,__product-name__

KRATOS_COURIER_HTTP_HOST=monolith:3000
SENTRY_DSN=mock

# @saflib/email
NODEMAILER_TRANSPORT_CONFIG=

# template-package-http
__PRODUCT_NAME___SERVICE_HTTP_HOST=monolith:3001

ADMIN_EMAILS=admin@__organization-name__.com